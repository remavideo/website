# Hides the dashboard link/route from the marketing site when set to "true".
VITE_DASHBOARD_OFF=

# Upstash Redis (REST API) — used to store early-access waitlist emails.
# Set automatically by the Upstash integration on Vercel, or get them from
# https://console.upstash.com/.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
